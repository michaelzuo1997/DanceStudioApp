{
  "name": "dance-studio-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "test": "jest",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:all": "eas build --platform all",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.0",
    "@supabase/supabase-js": "^2.95.3",
    "date-fns": "^4.1.0",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "^17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/@react-native-async-storage/async-storage.js",
      "^expo-router$": "<rootDir>/src/__mocks__/expo-router.js",
      "^expo-localization$": "<rootDir>/src/__mocks__/expo-localization.js",
      "^../../src/lib/supabase$": "<rootDir>/src/__mocks__/supabase.js",
      "^../../../src/lib/supabase$": "<rootDir>/src/__mocks__/supabase.js",
      "^../../src/context/AuthContext$": "<rootDir>/src/__mocks__/AuthContext.js",
      "^../../../src/context/AuthContext$": "<rootDir>/src/__mocks__/AuthContext.js",
      "^../../src/context/LanguageContext$": "<rootDir>/src/__mocks__/LanguageContext.js",
      "^../../../src/context/LanguageContext$": "<rootDir>/src/__mocks__/LanguageContext.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|react-navigation|@react-navigation|@supabase|i18next|react-i18next))"
    ]
  }
}
